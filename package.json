{
  "name": "docsino",
  "version": "0.0.1",
  "description": "Repository-aware documentation organizer",
  "type": "module",
  "bin": {
    "docsino": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "latest",
    "commander": "^15.0.0",
    "okapibm25": "latest",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "biome": "latest",
    "tsup": "latest",
    "typescript": "^5.8.0",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT"
}
